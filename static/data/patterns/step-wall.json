{
    "description":"A standard wall structure",
    "cell_type":"standard",
    "tile_size":{
        "width":{"cells":1, "repeat":"yes"},
        "height":{"cells":3, "repeat":"yes"},
        "depth":{"cells":2, "repeat":"no"}
    },

    "start_tiles":["start-a", "start-b", "start-c"],

    "tile_types":{
